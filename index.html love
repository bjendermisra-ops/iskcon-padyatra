    function updateAllTimers() {
      const timers = document.querySelectorAll('[data-countdown-id]');
      const cDict = dict[appState.currentLanguage];
      timers.forEach(t => {
        const targetTime = new Date(t.getAttribute('data-time')).getTime();
        const now = new Date().getTime();
        const diff = targetTime - now;
        if (isNaN(targetTime) || diff <= 0) { t.textContent = cDict.expired; t.style.color = '#8E8A9F'; return; }
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const mins = Math.floor((diff % 3600000) / 60000);
        const secs = Math.floor((diff % 60000) / 1000);
        t.textContent = (days > 0 ? `${days}${cDict.days} ` : '') + `${hours}${cDict.hours} ${mins}${cDict.minutes} ${secs}${cDict.seconds}`;
      });
    }

