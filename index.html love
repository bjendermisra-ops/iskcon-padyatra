    function renderUserPadyatras() {
      const query = (document.getElementById('user-search-input').value || '').toLowerCase();
      const container = document.getElementById('padyatras-container');
      const cDict = dict[appState.currentLanguage];

      if (!container) return;

      // Skeletal Loader Handler to prevent white-flashing screen anomalies
      if (!appState.dataLoaded) {
        container.innerHTML = `
          <div class="theme-card p-4 space-y-4">
            <div class="h-44 w-full skeleton-box rounded-md"></div>
            <div class="h-5 w-2/3 skeleton-box"></div>
            <div class="h-10 w-full skeleton-box"></div>
          </div>
          <div class="theme-card p-4 space-y-4">
            <div class="h-44 w-full skeleton-box rounded-md"></div>
            <div class="h-5 w-2/3 skeleton-box"></div>
            <div class="h-10 w-full skeleton-box"></div>
          </div>
          <div class="theme-card p-4 space-y-4">
            <div class="h-44 w-full skeleton-box rounded-md"></div>
            <div class="h-5 w-2/3 skeleton-box"></div>
            <div class="h-10 w-full skeleton-box"></div>
          </div>
        `;
        return;
      }

      const filtered = appState.padyatras.map(item => {
        let distanceVal = null;
        if (appState.userLatLng && item.liveState && item.liveState.gps) {
          distanceVal = getDistanceBetweenCoordinates(
            appState.userLatLng.lat,
            appState.userLatLng.lng,
            item.liveState.gps.lat,
            item.liveState.gps.lng
          );
        }
        return { ...item, computedDistance: distanceVal };
      }).filter(item => {
        const nameLoc = ((item.name && item.name[appState.currentLanguage]) || (item.name && item.name['en']) || '').toLowerCase();
        const matchesSearch = nameLoc.includes(query) || (item.currentCity && item.currentCity.toLowerCase().includes(query));
        
        // Exact same evaluation of live states for cards and tabs filters (Fixes the Live Tab empty bug)
        const isLive = (item.liveState && (item.liveState.isLive === true || item.liveState.isLive === 'true')) || (item.status && item.status.toLowerCase() === 'live');
        
        if (appState.userFilter === 'live') return matchesSearch && isLive;
        if (appState.userFilter === 'favorites') return matchesSearch && appState.favorites.includes(item.id);
        return matchesSearch;
      });

      if (appState.userLatLng) {
        filtered.sort((a, b) => {
          if (a.computedDistance !== null && b.computedDistance !== null) {
            return a.computedDistance - b.computedDistance;
          }
          return 0;
        });
      }

      const foundCountEl = document.getElementById('padyatras-found-count');
      if (foundCountEl) {
        foundCountEl.textContent = cDict.showingCount.replace('{n}', filtered.length);
      }

      const liveItems = appState.padyatras.filter(p => {
        return p.liveState 
          && (p.liveState.isLive === true || p.liveState.isLive === 'true')
          && p.liveState.ytVideoId 
          && p.liveState.ytVideoId.trim() !== '';
      }).map(item => {
        let distanceVal = null;
        if (appState.userLatLng && item.liveState && item.liveState.gps) {
          distanceVal = getDistanceBetweenCoordinates(
            appState.userLatLng.lat,
            appState.userLatLng.lng,
            item.liveState.gps.lat,
            item.liveState.gps.lng
          );
        }
        return { ...item, computedDistance: distanceVal };
      });

      if (appState.userLatLng) {
        liveItems.sort((a, b) => {
          if (a.computedDistance !== null && b.computedDistance !== null) {
            return a.computedDistance - b.computedDistance;
          }
          return 0;
        });
      }

