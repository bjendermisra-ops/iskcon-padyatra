    function syncDynamicStatsOverview() {
      database.ref('globalStats').once('value', snap => {
        const dbStats = snap.val();
        
        let totalBooks = 0;
        let totalPrasadam = 0;
        let totalDistance = 0;
        let totalTowns = 0;

        if (dbStats) {
          totalBooks = dbStats.books;
          totalPrasadam = dbStats.prasadam;
          totalDistance = dbStats.distance;
          totalTowns = dbStats.towns;
        } else {
          appState.padyatras.forEach(p => {
            if (p.stats) {
              totalBooks += (p.stats.books || 0);
              totalPrasadam += (p.stats.prasadam || 0);
              totalDistance += (p.stats.distance || 0);
            }
            if (p.route) {
              totalTowns += p.route.length;
            }
          });
        }

        const ids = ['books', 'prasadam', 'distance', 'towns'];
        ids.forEach(id => {
          const sk = document.getElementById(`global-stat-${id}-skeleton`);
          if (sk) sk.classList.add('hidden');
        });

        const bEl = document.getElementById('global-stat-books');
        const pEl = document.getElementById('global-stat-prasadam');
        const dEl = document.getElementById('global-stat-distance');
        const tEl = document.getElementById('global-stat-towns');

        if (bEl) { bEl.textContent = totalBooks.toLocaleString() + '+'; bEl.classList.remove('hidden'); }
        if (pEl) { pEl.textContent = totalPrasadam.toLocaleString() + '+'; pEl.classList.remove('hidden'); }
        if (dEl) { dEl.textContent = totalDistance.toLocaleString() + ' km'; dEl.classList.remove('hidden'); }
        if (tEl) { tEl.textContent = totalTowns.toLocaleString() + '+'; tEl.classList.remove('hidden'); }
      });
    }

