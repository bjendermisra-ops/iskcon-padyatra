    function getDeviceFingerprint() {
      let f = localStorage.getItem('tribute_device_id');
      if (!f) {
        const arr = new Uint32Array(4);
        window.crypto.getRandomValues(arr);
        f = 'dev_' + Array.from(arr, dec => dec.toString(16).padStart(8, '0')).join('');
        localStorage.setItem('tribute_device_id', f);
      }
      return f;
    }

    function renderTributesWallList(wishesObj) {
      const container = document.getElementById('tributes-feed-scroll');
      if (!container) return;
      container.innerHTML = '';

      const devId = getDeviceFingerprint();
      const list = Object.keys(wishesObj).map(key => ({
        deviceId: key,
        ...wishesObj[key]
      }));

      const displayed = list.filter(w => {
        const elapsed = Date.now() - w.timestamp;
        const isLocked = elapsed >= 600000;
        return isLocked || w.deviceId === devId;
      });

      displayed.sort((a, b) => b.timestamp - a.timestamp);

      const finalizedCount = list.filter(w => (Date.now() - w.timestamp) >= 600000).length;
      document.getElementById('total-tributes-badge').textContent = `${finalizedCount} Tributes`;

      if (displayed.length === 0) {
        container.innerHTML = `<div class="col-span-1 sm:col-span-3 text-center py-8 text-xs text-theme-dim italic font-devanagari">No tributes approved yet. Be the first to write! 🙏</div>`;
        return;
      }

      displayed.forEach(w => {
        const isMyPending = (w.deviceId === devId && (Date.now() - w.timestamp) < 600000);
        const cardBg = isMyPending 
          ? "bg-gradient-to-br from-[#1E173C] via-[#0E091E] to-[#1E173C] border-violet-500/30" 
          : "theme-panel";

        const cleanMessage = escapeHtml(w.message);
        const cleanName = escapeHtml(w.senderName);
        const cleanLocation = escapeHtml(w.location);

        container.innerHTML += `
          <div class="${cardBg} border p-5 rounded-[22px] space-y-3 flex flex-col justify-between shadow-sm animate-fade-in relative overflow-hidden">
            ${isMyPending ? `
              <div class="absolute top-2.5 right-2.5 flex items-center gap-1 bg-violet-500 text-white font-bold text-[8px] uppercase px-2 py-0.5 rounded tracking-wide animate-pulse">
                ⏳ Drafting
              </div>
            ` : ''}
            <p class="text-xs text-theme-main italic leading-relaxed font-devanagari whitespace-pre-wrap break-words scaled-text">"${cleanMessage}"</p>
            <div class="flex justify-between items-center text-[10px] border-t border-[var(--border)] pt-2.5 text-[var(--saffron)] font-bold uppercase tracking-wide font-devanagari gap-2">
              <span class="break-words">👤 ${cleanName}</span>
              <span class="break-words">📍 ${cleanLocation}</span>
            </div>
          </div>
        `;
      });
    }

