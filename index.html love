        container.appendChild(header);

        grouped[dateKey].forEach((ph, pIndex) => {
          const cardId = `darshan-card-${ph.id || pIndex}`;
          const imgId = `darshan-img-${ph.id || pIndex}`;

          const cleanCaption = escapeHtml(ph.caption);

          const card = document.createElement('div');
          card.id = cardId;
          card.className = 'darshan-card cursor-pointer border shadow-sm';
          card.onclick = () => openLightbox(ph.url, ph.caption, `${ph.date || ''} ${ph.time || ''}`);
          card.innerHTML = `
            <div class="relative overflow-hidden">
              <img id="${imgId}" src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100' height='100' viewBox='0 0 100 100'><rect width='100%' height='100%' fill='%231c1912'></rect></svg>" alt="${cleanCaption}"
                   class="w-full h-28 object-cover">
              <div class="absolute top-2 right-2">
                <span class="text-[7px] bg-black/70 text-pink-455 px-1.5 py-0.5 rounded font-bold">${ph.time || ''}</span>
              </div>
            </div>
            <div class="darshan-card-info">
              <div class="darshan-date-badge"><i class="fas fa-calendar-alt"></i> ${ph.date || ''}</div>
              <p class="text-[10px] text-theme-main font-medium line-clamp-2 leading-tight font-devanagari scaled-text">${cleanCaption}</p>
            </div>`;
          container.appendChild(card);

          const targetImg = document.getElementById(imgId);
          if (targetImg) {
            executeProgressiveImageLoading(targetImg, ph.url);
          }
        });
      });
    }

    function openLightbox(url, caption, date) {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox-caption').textContent = caption;
      document.getElementById('lightbox-date').textContent = date;
      document.getElementById('gallery-lightbox').classList.add('open');
    }
    function closeLightbox() {
      document.getElementById('gallery-lightbox').classList.remove('open');
    }

    function closeModal() {
      if (appState.onGroundViewersRef && appState.onGroundViewersCallback) {
        appState.onGroundViewersRef.off('value', appState.onGroundViewersCallback);
        appState.onGroundViewersRef = null;
        appState.onGroundViewersCallback = null;
      }

      const detailModal = document.getElementById('padyatra-detail-modal');
      if (detailModal && !detailModal.classList.contains('hidden')) {
        detailModal.classList.add('hidden');
        appState.selectedPadyatraIdForModal = null;
        document.body.style.overflow = '';
        if (appState.mapInstance) {
          appState.mapInstance.remove();
          appState.mapInstance = null;
          appState.mapMarker = null;
          appState.mapPolyline = null;
        }
        if (history.state && history.state.modalOpen) {
          history.back();
        }
      }
    }

    function toggleModalFavorite() { if (appState.selectedPadyatraIdForModal) { toggleFavorite(appState.selectedPadyatraIdForModal); updateModalFavBtnState(); } }
    
    function updateModalFavBtnState() {
      const isFav = appState.favorites.includes(appState.selectedPadyatraIdForModal);
      const btn = document.getElementById('modal-fav-toggle-btn');
      if (!btn) return;
      btn.className = isFav ? "h-11 btn-premium-primary text-xs font-bold px-4 rounded-full col-span-1" : "h-11 btn-premium-secondary text-xs font-bold px-4 rounded-full col-span-1";
    }

    function toggleFavorite(id, event) {
      if (event) event.stopPropagation();
      const idx = appState.favorites.indexOf(id);
      if (idx > -1) { appState.favorites.splice(idx, 1); }
      else { appState.favorites.push(id); }
      saveLocalFavorites();
      localizeUI();
      renderUserPadyatras();
    }

    function launchFullscreenDarshan(id) {
      const item = appState.padyatras.find(p => p.id === id);
      if (!item || !item.liveState) return;

      history.pushState({ modalOpen: true, modalType: 'fullscreen', id: id }, "");

      appState.isFullscreenActive = true;
      const overlay = document.getElementById('immersive-fullscreen-overlay');
      overlay.classList.remove('hidden');

      document.getElementById('fs-p-title').textContent = (item.name && item.name[appState.currentLanguage]) || (item.name && item.name['en']) || '';
      document.getElementById('fs-current-city').textContent = item.liveState.currentCity || item.currentCity || '—';
      document.getElementById('fs-precise-spot').textContent = item.liveState.preciseLandmark || item.preciseLandmark || 'Not Specified';

      const fsLoader = document.getElementById('fs-darshan-loader');
      if (fsLoader) fsLoader.classList.remove('hidden');

      if (appState.ytPlayers[id]) {
        try { appState.ytPlayers[id].destroy(); } catch(e){}
        delete appState.ytPlayers[id];
      }

      const fsContainer = document.getElementById('yt-fullscreen-player-container');
      if (fsContainer) {
        fsContainer.innerHTML = `<div id="yt-fullscreen-inner" style="position:absolute;top:-12%;left:-12%;width:124%;height:124%;pointer-events:none;"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;height:12%;background:#000;z-index:8;"></div>
          <div style="position:absolute;top:0;left:0;right:0;height:12%;background:#000;z-index:8;"></div>`;
      }

      updateUIReactionCounters();

      setTimeout(() => {
        const lsObj = item.liveState;
        
        if (lsObj.mode === 'agora') {
          const innerEl = document.getElementById('yt-fullscreen-player-container');
          if (innerEl) innerEl.innerHTML = `<div id="yt-fullscreen-inner" style="width:100%;height:100%;position:relative;"></div>`;
          connectAgoraDevoteeSDKStream('yt-fullscreen-inner', lsObj.appId);
          if (fsLoader) fsLoader.classList.add('hidden');
          return;
        }

        if (ytApiReady && window.YT && window.YT.Player) {
          let tSec = lsObj.ytTime || 0;
          if (lsObj.timestamp) tSec += Math.min((Date.now() - lsObj.timestamp) / 1000, 20);

          appState.ytPlayers[id] = new YT.Player('yt-fullscreen-inner', {
            height: '100%', width: '100%',
            videoId: lsObj.ytVideoId,
            playerVars: { autoplay: 1, controls: 0, rel: 0, modestbranding: 1, playsinline: 1, mute: appState.isMuted ? 1 : 0, start: Math.max(0, Math.floor(tSec - 2)) },
            events: {
              onReady: (e) => {
                if (appState.isMuted) {
                  e.target.mute();
                } else {
                  e.target.unMute();
                  e.target.setVolume(100);
                }
                e.target.seekTo(tSec, true);
                e.target.playVideo();
                setTimeout(() => { if (fsLoader) fsLoader.classList.add('hidden'); }, 300);
                showUnmutePrompt(id, true);
              },
              onStateChange: (e) => { if (e.data === 1 && fsLoader) fsLoader.classList.add('hidden'); },
              onError: () => { buildFsIframeFallback(id, item.liveState, tSec, fsLoader); }
            }
          });
        } else {
          buildFsIframeFallback(id, item.liveState, 0, fsLoader);
        }
      }, 50);
    }

    function buildFsIframeFallback(id, lsObj, tSec, loaderEl) {
      const fsInner = document.getElementById('yt-fullscreen-inner');
      if (!fsInner) return;
      const src = `https://www.youtube-nocookie.com/embed/${lsObj.ytVideoId}?autoplay=1&mute=${appState.isMuted ? 1 : 0}&controls=0&rel=0&modestbranding=1&playsinline=1&iv_load_policy=3&disablekb=1&fs=0&start=${Math.max(0,Math.floor(tSec))}&enablejsapi=1`;
      fsInner.outerHTML = `<iframe src="${src}" style="position:absolute;top:-12%;left:-12%;width:124%;height:124%;border:none;pointer-events:none;" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope" allowfullscreen></iframe>`;
      setTimeout(() => { if (loaderEl) loaderEl.classList.add('hidden'); showUnmutePrompt(id, true); }, 1000);
    }

    function closeFullscreenDarshan() {
      closeFullscreenDarshanInternal();
      if (history.state && history.state.modalOpen) {
        history.back();
      }
    }

    function closeFullscreenDarshanInternal() {
      appState.isFullscreenActive = false;
      document.getElementById('immersive-fullscreen-overlay').classList.add('hidden');
      const id = appState.activeLivePadyatraId;
      if (id) {
        if (appState.ytPlayers[id]) {
          try { appState.ytPlayers[id].destroy(); } catch(e){}
          delete appState.ytPlayers[id];
        }
        const p = document.getElementById('fs-unmute-prompt');
        if (p) p.remove();
        lastRenderedLiveId = null; 
        setTimeout(() => renderUserPadyatras(), 50);
      }
    }

    window.openShareOverlay = (id) => {
      currentlySharingPadyatraId = id || appState.activeLivePadyatraId;
      localizeUI(); 
      history.pushState({ modalOpen: true, modalType: 'share' }, "");
      document.getElementById('share-overlay').classList.remove('hidden');
      document.getElementById('share-overlay').classList.add('flex');
    };
    
    window.closeShareOverlay = () => {
      const shareOverlay = document.getElementById('share-overlay');
      if (shareOverlay && !shareOverlay.classList.contains('hidden')) {
        shareOverlay.classList.add('hidden');
        shareOverlay.classList.remove('flex');
        if (history.state && history.state.modalOpen) {
          history.back();
        }
      }
    };
    
    window.shareVia = (platform) => {
      const playStoreUrl = "https://play.google.com/store/apps/details?id=iskcon.hadapsar";
      let padyatraName = "ISKCON Padyatra";
      if (currentlySharingPadyatraId) {
        const item = appState.padyatras.find(p => p.id === currentlySharingPadyatraId);
        if (item) {
          padyatraName = (item.name && item.name[appState.currentLanguage]) || (item.name && item.name['en']) || "ISKCON Padyatra";
        }
      }

      let msg = "";
      if (appState.currentLanguage === 'hi') {
        msg = `🚩 *श्रील प्रभुपाद की जय!* 🙏\n*दिव्य लाइव दर्शन आमंत्रण* 🚶✨\n\nआप सभी भक्तों को जानकर अत्यंत हर्ष होगा कि *${padyatraName}* का भव्य लाइव दर्शन प्रारंभ हो चुका है!\n\nघर बैठे इस पावन पदयात्रा और दिव्य हरिनाम संकीर्तन के दर्शन का दिव्य लाभ उठाएं।\n\n👉 *दर्शन करने के लिए नीचे दिए गए लिंक से अभी ऐप डाउनलोड करें:* \n🔗 ${playStoreUrl}\n\n✨ *कृपया इस संदेश को अपने परिवार और मित्रों के साथ साझा करें ताकि वे भी इस दिव्य दर्शन के पुण्य के भागी बन सकें!* 🙏🚩`;
      } else if (appState.currentLanguage === 'mr') {
        msg = `🚩 *श्रील प्रभुपाद की जय!* 🙏\n*दिव्य लाइव दर्शन आमंत्रण* 🚶✨\n\nसर्व भक्तांना अत्यंत आनंदाने कळविण्यात येते की *${padyatraName}* चे भव्य लाइव्ह दर्शन सुरू झाले आहे!\n\nघर बसून या पावन पदयात्रेचे आणि दिव्य हरिनाम संकीर्तनाचे दर्शन घ्या आणि कृपा प्रसादाचे भागीदार व्हा.\n\n👉 *दर्शन घेण्यासाठी खालील लिंकवरून आत्ताच ॲप डाउनलोड करा:* \n🔗 ${playStoreUrl}\n\n✨ *कृपया हा संदेश तुमच्या कुटुंबियांसोबत आणि मित्रांसोबत शेअर करा जेणेकरून त्यांनाही या दिव्य दर्शनाचा लाभ घेता येईल!* 🙏🚩`;
      } else {
        msg = `🚩 *Srila Prabhupada Ki Jaya!* 🙏\n*Divine Live Darshan Invitation* 🚶✨\n\nWe are pleased to inform you that the auspicious Live Darshan of *${padyatraName}* has begun!\n\nReceive the blessings of this holy pilgrimage and Harinama Sankirtana from home.\n\n👉 *To view, download our Mobile App now:* \n🔗 ${playStoreUrl}\n\n✨ *Please share this invitation with your family and friends!* 🙏🚩`;
      }

      const encodedMsg = encodeURIComponent(msg);
      if (platform === 'whatsapp') { 
        window.location.href = 'whatsapp://send?text=' + encodedMsg; 
        closeShareOverlay(); 
      }
    };
  </script>
