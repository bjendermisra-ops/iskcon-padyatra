    function syncDevoteePlayerEngine(id, liveState) {
      const isFs = appState.isFullscreenActive;
      const containerId = isFs ? 'yt-fullscreen-player-container' : `yt-devotee-player-${id}`;
      const loaderEl = isFs ? document.getElementById('fs-darshan-loader') : document.getElementById(`card-darshan-loader-${id}`);
      const videoOffEl = document.getElementById(isFs ? 'fs-video-off-overlay' : `user-video-off-overlay-${id}`);

      if (videoOffEl) videoOffEl.classList.toggle('hidden', !liveState.videoMuted);

      if (liveState.mode === 'agora') {
        const isYtWrapper = document.getElementById(isFs ? 'yt-fullscreen-player-container' : `yt-devotee-player-${id}`);
        if (isYtWrapper) {
          isYtWrapper.outerHTML = `<div id="${containerId}" style="width:100%;height:100%;position:relative;"></div>`;
        }
        
        if (appState.ytPlayers[id]) {
          try { appState.ytPlayers[id].destroy(); } catch(e){}
          delete appState.ytPlayers[id];
        }

        connectAgoraDevoteeSDKStream(containerId, liveState.appId);
        if (loaderEl) loaderEl.classList.add('hidden');
        return;
      }

      let targetSec = liveState.ytTime || 0;
      if (liveState.timestamp) {
        const elapsed = (Date.now() - liveState.timestamp) / 1000;
        targetSec += Math.min(elapsed, 20);
      }

      if (appState.ytPlayers[id]) {
        const player = appState.ytPlayers[id];
        try {
          if (typeof player.getPlayerState === 'function') {
            const ytState = player.getPlayerState();
            if (ytState !== liveState.ytState) {
              if (liveState.ytState === 1) player.playVideo();
              else if (liveState.ytState === 2) player.pauseVideo();
            }
          }
          if (typeof player.getCurrentTime === 'function') {
            const ytTime = player.getCurrentTime();
            if (Math.abs(ytTime - targetSec) > 5) {
              player.seekTo(targetSec, true);
            }
          }
        } catch(e) {}
        if (loaderEl) loaderEl.classList.add('hidden');
        return;
      }

      if (appState.ytInitialized[containerId]) return;
      appState.ytInitialized[containerId] = true;

      const buildStealthIframe = () => {
        const container = document.getElementById(containerId);
        if (!container) return;

        const parentId = containerId;
        const stealthParams = [
          `autoplay=1`,
          `mute=${appState.isMuted ? 1 : 0}`,
          `controls=0`,
          `rel=0`,
          `modestbranding=1`,
          `playsinline=1`,
          `iv_load_policy=3`,
          `disablekb=1`,
          `fs=0`,
          `start=${Math.max(0, Math.floor(targetSec - 2))}`,
          `enablejsapi=1`,
          `origin=${encodeURIComponent(window.location.origin)}`
        ].join('&');

        const iframeHtml = `<iframe 
          id="${parentId}" 
          src="https://www.youtube-nocookie.com/embed/${liveState.ytVideoId}?${stealthParams}"
          style="position:absolute;top:-12%;left:-12%;width:124%;height:124%;border:none;pointer-events:none;"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope"
          allowfullscreen>
        </iframe>`;
        container.outerHTML = iframeHtml;

        setTimeout(() => { if (loaderEl) loaderEl.classList.add('hidden'); }, 1000);
        showUnmutePrompt(id, isFs);
      };

      if (ytApiReady && window.YT && window.YT.Player) {
        const container = document.getElementById(containerId);
        if (!container) return;
        if (container.tagName === 'IFRAME') {
          container.outerHTML = `<div id="${containerId}" style="position:absolute;top:-12%;left:-12%;width:124%;height:124%;pointer-events:none;"></div>`;
        }
        try {
          appState.ytPlayers[id] = new YT.Player(containerId, {
            height: '100%', width: '100%',
            videoId: liveState.ytVideoId,
            playerVars: {
              autoplay: 1, controls: 0, rel: 0, modestbranding: 1,
              playsinline: 1, disablekb: 1, fs: 0, iv_load_policy: 3, mute: appState.isMuted ? 1 : 0,
              start: Math.max(0, Math.floor(targetSec - 2))
            },
            events: {
              onReady: (e) => {
                if (appState.isMuted) {
                  e.target.mute();
                } else {
                  e.target.unMute();
                  e.target.setVolume(100);
                }
                e.target.seekTo(targetSec, true);
                e.target.playVideo();
                setTimeout(() => { if (loaderEl) loaderEl.classList.add('hidden'); }, 300);
                showUnmutePrompt(id, isFs);
              },
              onStateChange: (e) => {
                if (e.data === 1 && loaderEl) loaderEl.classList.add('hidden');
              },
              onError: () => { buildStealthIframe(); }
            }
          });
        } catch(err) {
          buildStealthIframe();
        }
      } else {
        buildStealthIframe();
      }
    }

    async function connectAgoraDevoteeSDKStream(containerId, appId) {
      if (!appState.agoraClient) return;
      try {
        await appState.agoraClient.leave().catch(()=>{});
        
        appState.agoraClient.on("user-published", async (user, mediaType) => {
          await appState.agoraClient.subscribe(user, mediaType);
          if (mediaType === "video") {
            const remoteVideoTrack = user.videoTrack;
            remoteVideoTrack.play(containerId);
          }
          if (mediaType === "audio") {
            const remoteAudioTrack = user.audioTrack;
            remoteAudioTrack.play();
          }
        });

        await appState.agoraClient.join(appId, "iskcon_live", null, null);
      } catch(e) {
        console.error("Agora join failed", e);
      }
    }

    function showUnmutePrompt(padId, isFs) {
      const promptId = isFs ? 'fs-unmute-prompt' : `card-unmute-prompt-${padId}`;
      if (document.getElementById(promptId)) {
        updateSpeakerIconUI(padId, isFs);
        return;
      }

      const stageEl = isFs
        ? document.getElementById('immersive-fullscreen-overlay')
        : document.querySelector(`#yt-devotee-player-${padId}`)?.closest('.yt-stealth-wrapper')?.parentElement;

      if (!stageEl) return;

      const btn = document.createElement('button');
      btn.id = promptId;
      btn.className = 'stream-audio-control-btn shadow-md';
      btn.innerHTML = appState.isMuted ? '<i class="fas fa-volume-mute"></i>' : '<i class="fas fa-volume-up"></i>';
      btn.onclick = (e) => {
        e.stopPropagation();
        toggleAudioSankirtanState(padId, isFs);
      };
      stageEl.appendChild(btn);
    }

    function toggleAudioSankirtanState(padId, isFs) {
      appState.isMuted = !appState.isMuted;
      
      const cardBtn = document.getElementById(`card-unmute-prompt-${padId}`);
      const fsBtn = document.getElementById('fs-unmute-prompt');
      const iconHtml = appState.isMuted ? '<i class="fas fa-volume-mute"></i>' : '<i class="fas fa-volume-up"></i>';
      
      if (cardBtn) cardBtn.innerHTML = iconHtml;
      if (fsBtn) fsBtn.innerHTML = iconHtml;

      const player = appState.ytPlayers[padId];
      if (player) {
        try {
          if (appState.isMuted) {
            player.mute();
          } else {
            player.unMute();
            player.setVolume(100);
            player.playVideo();
          }
        } catch(err) {
          console.warn("YouTube Direct API Audio call failed", err);
        }
      }
      showToast(appState.isMuted ? "Audio Muted" : "🎵 Sankirtan Audio Unmuted!", "success");
    }

    function updateSpeakerIconUI(padId, isFs) {
      const btn = document.getElementById(isFs ? 'fs-unmute-prompt' : `card-unmute-prompt-${padId}`);
      if (btn) {
        btn.innerHTML = appState.isMuted ? '<i class="fas fa-volume-mute"></i>' : '<i class="fas fa-volume-up"></i>';
      }
    }

    function registerDevoteePresence(padId) {
