    function executeProgressiveImageLoading(imgElement, srcUrl) {
      if (!srcUrl) return;
      imgElement.classList.add('progressive-img');
      const parent = imgElement.parentElement;
      if (parent) parent.classList.add('img-loading-shimmer');

      const tempImage = new Image();
      tempImage.src = srcUrl;
      tempImage.onload = function() {
        imgElement.src = srcUrl;
        imgElement.classList.add('loaded');
        if (parent) parent.classList.remove('img-loading-shimmer');
      };
      tempImage.onerror = function() {
        imgElement.src = 'https://images.unsplash.com/photo-1545128485-c400e7702796?auto=format&fit=crop&q=80&w=800';
        imgElement.classList.add('loaded');
        if (parent) parent.classList.remove('img-loading-shimmer');
      };
    }

